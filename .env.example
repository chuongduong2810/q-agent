# docker compose secrets — copy to `.env` (gitignored) and fill in.
#   cp .env.example .env

# REQUIRED. Long random string. Derives the credential-encryption key and signs
# auth JWTs. Changing it later invalidates stored provider/Claude credentials.
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
QAGENT_SECRET_KEY=change-me-to-a-long-random-string

# First admin, seeded on an empty database — this is how you first sign in.
QAGENT_ADMIN_EMAIL=admin@qagent.local
QAGENT_ADMIN_PASSWORD=change-me

# Optional — default Claude model for AI actions.
QAGENT_CLAUDE_MODEL=claude-sonnet-5

# Bundled Postgres (the `db` service). These seed the database container and are
# assembled into QAGENT_DATABASE_URL in docker-compose.yml. The DB is internal
# to the compose network (not published to the host), so defaults are fine —
# change the password for anything exposed.
QAGENT_DB_USER=qagent
QAGENT_DB_PASSWORD=qagent
QAGENT_DB_NAME=qagent
