# Q-Agent backend configuration. Copy to `.env` and adjust.
# All vars are prefixed QAGENT_.

# Server
QAGENT_HOST=127.0.0.1
QAGENT_PORT=8787

# Secret used to derive the credential-encryption key + sign auth JWTs. CHANGE THIS.
QAGENT_SECRET_KEY=change-me-to-a-long-random-string

# Auth (ADR 0007). OFF by default → local-first single-user install works unchanged.
# Set to true for a shared/multi-user server deployment (enables the global guard).
QAGENT_AUTH_REQUIRED=false
# Set the Secure flag on auth cookies. Keep false for http-localhost dev; set true
# behind HTTPS in production. When true, the password-reset token is NOT echoed.
QAGENT_COOKIE_SECURE=false
# Optional admin seed: when both are set and the users table is empty, an active
# admin account is created on startup.
QAGENT_ADMIN_EMAIL=
QAGENT_ADMIN_PASSWORD=

# Claude CLI (must be installed + authenticated: `claude login`)
QAGENT_CLAUDE_BIN=claude
QAGENT_CLAUDE_MODEL=claude-sonnet-5
QAGENT_CLAUDE_TIMEOUT_S=300

# Playwright (invoked via npx in the app/ workspace)
QAGENT_EXEC_TIMEOUT_S=600
