# Q-Agent backend configuration. Copy to `.env` and adjust.
# All vars are prefixed QAGENT_.

# Server
QAGENT_HOST=127.0.0.1
QAGENT_PORT=8787

# Secret used to derive the credential-encryption key. CHANGE THIS.
QAGENT_SECRET_KEY=change-me-to-a-long-random-string

# Claude CLI (must be installed + authenticated: `claude login`)
QAGENT_CLAUDE_BIN=claude
QAGENT_CLAUDE_MODEL=claude-sonnet-5
QAGENT_CLAUDE_TIMEOUT_S=300

# Playwright (invoked via npx in the app/ workspace)
QAGENT_EXEC_TIMEOUT_S=600
